NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# server-only - never expose to the browser. Used by the user management
# panel (app/dashboard/users) and the stage 4 webhook routes - calls that
# must bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# stage 4 - CRM -> Make write-back (section 4.2). The Make scenario that
# receives this call and writes to עדכנית.
MAKE_OUTGOING_WEBHOOK_URL=https://hook.eu1.make.com/your-scenario-id

# stage 4 - Make -> CRM new-document push (section 4.3b). Set the same value
# in Make's HTTP module as a custom header: x-webhook-secret.
MAKE_INCOMING_WEBHOOK_SECRET=choose-a-long-random-string

# case import pilot - Make -> CRM case sync from עדכנית (app/api/webhooks/case-sync).
# Set the same value in Make's HTTP module as a custom header: x-webhook-secret.
# Only case_numbers already listed in case_sync_allowlist (0009) get written.
MAKE_CASE_SYNC_WEBHOOK_SECRET=choose-a-different-long-random-string

# task import pilot - Make -> CRM task sync from עדכנית (app/api/webhooks/task-sync).
# Set the same value in Make's HTTP module as a custom header: x-webhook-secret.
# Gated by the same case_sync_allowlist as case-sync.
MAKE_TASK_SYNC_WEBHOOK_SECRET=choose-yet-another-long-random-string

# deadline import pilot - Make -> CRM deadline sync from עדכנית's custom
# fields (app/api/webhooks/deadline-sync). Same header/gate as the others.
MAKE_DEADLINE_SYNC_WEBHOOK_SECRET=choose-still-another-long-random-string
